# API ключ для Google Gemini (получить можно на https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Примечание: Для локальной разработки скопируйте этот файл в .env и вставьте свой ключ.
# При деплое (например, на Vercel или Netlify) добавьте GEMINI_API_KEY в переменные окружения (Environment Variables).
