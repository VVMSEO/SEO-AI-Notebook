rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidNote(data) {
      return hasOnlyAllowedFields(['uid', 'project', 'raw', 'refined', 'timestamp', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.project is string && data.project.size() > 0 && data.project.size() < 200 &&
             data.raw is string && data.raw.size() > 0 && data.raw.size() < 10000 &&
             data.refined is string && data.refined.size() > 0 && data.refined.size() < 10000 &&
             data.timestamp is string && data.timestamp.size() > 0 && data.timestamp.size() < 100 &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidTemplate(data) {
      return hasOnlyAllowedFields(['uid', 'text', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 10000 &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNote(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidNote(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /templates/{templateId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTemplate(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTemplate(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
